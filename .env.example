# Server
PORT=3000
NODE_ENV=development

# Database
# Leave unset to use mongodb://localhost:27017/cropsense.
MONGODB_URI=mongodb://localhost:27017/cropsense

# Auth
# Required in production. Use a long random value.
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d
AUTH_RATE_LIMIT=20

# Frontend integrations
# Optional. Enables Google Sign-In when configured.
GOOGLE_CLIENT_ID=

# Security
# Optional comma-separated list. Empty allows same-origin/local development.
# Example: https://your-domain.com,http://localhost:3000
CORS_ORIGIN=
